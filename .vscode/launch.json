    "version": "0.2.0",
    "configurations": [
        {
            "name": "Flutter-Responsive-Admin-Panel-or-Dashboard",
            "request": "launch",
            "type": "dart",
            "toolArgs": [
                "-d",
                "chrome",
                "--web-port",
                "3004"
            ]
        },
        {
            "name": "Flutter-Responsive-Admin-Panel-or-Dashboard (profile mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile",
            "toolArgs": [
                "-d",
                "chrome",
                "--web-port",
                "3004"
            ]
        },
        {
            "name": "Flutter-Responsive-Admin-Panel-or-Dashboard (release mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release",
            "toolArgs": [
                "-d",
                "chrome",
                "--web-port",
                "3004"
            ]
        }
    ]
}
